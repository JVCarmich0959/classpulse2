// ── BEHAVIOR BACKFILL ──
var BACKFILL_RUNNING=false;
function runBehaviorBackfill(){
  if(BACKFILL_RUNNING)return;
  BACKFILL_RUNNING=true;
  var statusEl=el('backfill-status');
  if(statusEl) statusEl.textContent='Fetching untagged rows…';
  var tok=SESSION.token||SB_KEY;
  // fetch rows with empty behaviors array
  fetch(SB_URL+'/rest/v1/incidents?behaviors=eq.%7B%7D&select=id,notes,student&limit=50',{
    headers:{'apikey':SB_KEY,'Authorization':'Bearer '+tok}
  }).then(function(r){return r.json();})
  .then(function(rows){
    if(!rows||!rows.length){
      if(statusEl) statusEl.textContent='All rows already tagged.';
      BACKFILL_RUNNING=false;
      return;
    }
    if(statusEl) statusEl.textContent='Tagging '+rows.length+' rows…';
    var done=0,failed=0;
    var BEH_LIST=BEHAVIORS.join(', ');
    function processNext(i){
      if(i>=rows.length){
        if(statusEl) statusEl.textContent='Done — tagged '+(done)+', failed '+failed+'.';
        BACKFILL_RUNNING=false;
        STATE.liveLoaded=false;STATE.liveRows=[];
        return;
      }
      var row=rows[i];
      var prompt='Given this incident note, return ONLY a JSON array of applicable behavior tags from this list: ['+BEH_LIST+']. Return [] if none clearly apply. Note: "'+((row.notes||'').slice(0,300)).replace(/"/g,"'")+'"';
      fetch('https://api.anthropic.com/v1/messages',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:100,messages:[{role:'user',content:prompt}]})
      }).then(function(r){return r.json();})
      .then(function(data){
        var text=(data.content&&data.content[0]&&data.content[0].text)||'[]';
        var match=text.match(/\[.*?\]/s);
        var tags=[];
        if(match){try{tags=JSON.parse(match[0]).filter(function(t){return BEHAVIORS.indexOf(t)>=0;});}catch(e){}}
        return fetch(SB_URL+'/rest/v1/incidents?id=eq.'+row.id,{
          method:'PATCH',
          headers:{'apikey':SB_KEY,'Authorization':'Bearer '+tok,'Content-Type':'application/json','Prefer':'return=minimal'},
          body:JSON.stringify({behaviors:tags})
        });
      }).then(function(){
        done++;
        if(statusEl) statusEl.textContent='Tagged '+done+'/'+rows.length+'…';
        setTimeout(function(){processNext(i+1);},400);
      }).catch(function(){
        failed++;
        setTimeout(function(){processNext(i+1);},400);
      });
    }
    processNext(0);
  }).catch(function(){
    if(statusEl) statusEl.textContent='Error fetching rows.';
    BACKFILL_RUNNING=false;
  });
}

