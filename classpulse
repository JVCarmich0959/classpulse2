    var blob=new Blob([swCode],{type:'text/javascript'});
    var swUrl=URL.createObjectURL(blob);
    navigator.serviceWorker.register(swUrl).then(function(){
      console.log('[SW] registered');
    }).catch(function(e){console.warn('[SW] failed',e);});
  }catch(e){console.warn('[SW] blob SW not supported',e);}
}

// ── INIT ──
initLogin();
initFreshness();
})();
</script>
